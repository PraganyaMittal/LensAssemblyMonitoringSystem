#include "resource.h"

#define APSTUDIO_READONLY_SYMBOLS
#define APSTUDIO_HIDDEN_SYMBOLS
#include "windows.h"
#undef APSTUDIO_HIDDEN_SYMBOLS
#undef APSTUDIO_READONLY_SYMBOLS

#if !defined(AFX_RESOURCE_DLL) || defined(AFX_TARG_ENU)
LANGUAGE 9, 1

/////////////////////////////////////////////////////////////////////////////
// Dialog

IDD_REGISTRATION DIALOGEX 0, 0, 340, 350
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Factory Agent - First Time Setup"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "Line Number:", IDC_STATIC, 10, 15, 80, 8
    EDITTEXT        IDC_LINE_NUMBER, 100, 12, 200, 14, ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "MC Number:", IDC_STATIC, 10, 35, 80, 8
    EDITTEXT        IDC_PC_NUMBER, 100, 32, 200, 14, ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "Config File Path:", IDC_STATIC, 10, 55, 80, 8
    EDITTEXT        IDC_CONFIG_PATH, 100, 52, 200, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "...", IDC_BROWSE_CONFIG, 305, 52, 20, 14

    LTEXT           "Log Folder Path:", IDC_STATIC, 10, 75, 80, 8
    EDITTEXT        IDC_LOG_PATH, 100, 72, 200, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "...", IDC_BROWSE_LOG, 305, 72, 20, 14

    LTEXT           "Model Folder Path:", IDC_STATIC, 10, 95, 80, 8
    EDITTEXT        IDC_MODEL_PATH, 100, 92, 200, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "...", IDC_BROWSE_MODEL, 305, 92, 20, 14

    LTEXT           "Model Version:", IDC_STATIC, 10, 115, 80, 8
    COMBOBOX        IDC_MODEL_VERSION, 100, 112, 80, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "EXE Name:", IDC_STATIC, 10, 135, 80, 8
    EDITTEXT        IDC_EXE_NAME, 100, 132, 200, 14, ES_AUTOHSCROLL

    LTEXT           "Server URL:", IDC_STATIC, 10, 155, 80, 8
    EDITTEXT        IDC_SERVER_URL, 100, 152, 200, 14, ES_AUTOHSCROLL

    LTEXT           "Rotation(hours):", IDC_STATIC, 10, 175, 80, 8
    EDITTEXT        IDC_ROTATION_INTERVAL, 100, 172, 200, 14, ES_AUTOHSCROLL

    LTEXT           "Result Data Path:", IDC_STATIC, 10, 195, 80, 8
    EDITTEXT        IDC_YIELD_PATH, 100, 192, 200, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "...", IDC_BROWSE_YIELD, 305, 192, 20, 14

    LTEXT           "Enter the configuration for this factory PC.", IDC_STATIC, 10, 215, 310, 8
    LTEXT           "Select the correct model version for this PC (e.g., 3.5 or 4.0).", IDC_STATIC, 10, 227, 310, 8
    LTEXT           "IP Address/Rotation will be auto-set if left default.", IDC_STATIC, 10, 239, 310, 8

    LTEXT           "Examples:", IDC_STATIC, 10, 255, 310, 8
    LTEXT           "Config: C:\\LAI\\LAI-Operational\\config.ini", IDC_STATIC, 10, 267, 310, 8
    LTEXT           "Log:    C:\\LAI\\LAI-WorkData\\Log", IDC_STATIC, 10, 279, 310, 8
    LTEXT           "Model:  C:\\LAI\\LAI-Operational\\Model", IDC_STATIC, 10, 291, 310, 8

    DEFPUSHBUTTON   "OK", IDOK, 160, 305, 70, 18
    PUSHBUTTON      "Cancel", IDCANCEL, 240, 305, 70, 18
END

#endif
