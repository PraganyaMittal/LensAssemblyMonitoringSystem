{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=LensAssemblyMonitoringDB;Trusted_Connection=True;TrustServerCertificate=True;Max Pool Size=300;MultipleActiveResultSets=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "HeartbeatTimeoutMinutes": 1,
    "MaxUploadSizeMB": 500
  },
  "LogSettings": {
    "BaseTimeoutSeconds": 30,
    "TimeoutPerMBSeconds": 5,
    "MaxTimeoutSeconds": 180,
    "ExpectedFileSizeMB": 15,
    "CacheSizeLimitMB": 100
  }
}